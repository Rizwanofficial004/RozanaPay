{
  "version": 2,
  "installCommand": "npm install --include=dev && npm run prisma:generate",
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "src": "/(.*)", "dest": "/api/[...path].js" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-schedules",
      "schedule": "0 0 * * *"
    }
  ]
}
