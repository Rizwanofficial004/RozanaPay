{
  "version": 2,
  "framework": null,
  "installCommand": "npm run install:all",
  "buildCommand": "cd backend && npm run prisma:generate && cd ../frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-schedules",
      "schedule": "0 0 * * *"
    }
  ]
}
